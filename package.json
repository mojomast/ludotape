{
  "name": "ludotape",
  "version": "0.1.0",
  "description": "Games you can rewind: deterministic browser-game framework",
  "type": "module",
  "engines": { "node": ">=20" },
  "exports": { ".": "./src/index.mjs", "./adapters": "./src/adapters.mjs", "./storage": "./src/storage.mjs", "./editor": "./src/editor.mjs", "./authoring": "./src/authoring.mjs" },
  "bin": { "ludotape": "./bin/ludotape.mjs" },
  "scripts": {
    "test": "node --test",
    "build": "node scripts/build.mjs",
    "benchmark": "node bench/benchmark.mjs",
    "example:basic": "node examples/run-basic-counter.mjs",
    "package-smoke": "node scripts/package-smoke.mjs",
    "smoke": "node scripts/smoke.mjs",
    "check": "npm test && npm run build && npm run benchmark && npm run smoke && npm run package-smoke",
    "prepack": "node scripts/build.mjs"
  },
  "license": "MIT",
  "author": "mojomast",
  "repository": {"type":"git","url":"git+https://github.com/mojomast/ludotape.git"},
  "homepage": "https://github.com/mojomast/ludotape#readme",
  "bugs": {"url":"https://github.com/mojomast/ludotape/issues"},
  "keywords": ["game", "deterministic", "replay", "browser"],
  "files": [
    "src",
    "bin",
    "bench/benchmark.mjs",
    "dist",
    "examples",
    "docs",
    "README.md",
    "SPEC.md",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "PRIVACY.md",
    "ROADMAP.md",
    "CHANGELOG.md",
    "SUPPORT.md",
    "LICENSE"
  ]
}
