{
  "name": "ludotape",
  "version": "0.1.0",
  "description": "Games you can rewind: deterministic browser-game framework",
  "type": "module",
  "engines": { "node": ">=20" },
  "exports": { ".": "./src/index.mjs", "./adapters": "./src/adapters.mjs", "./storage": "./src/storage.mjs", "./editor": "./src/editor.mjs" },
  "bin": { "ludotape": "./bin/ludotape.mjs" },
  "scripts": {
    "test": "node --test",
    "build": "node scripts/build.mjs",
    "benchmark": "node bench/benchmark.mjs",
    "smoke": "node scripts/smoke.mjs",
    "check": "npm test && npm run build && npm run benchmark && npm run smoke"
  },
  "license": "MIT",
  "keywords": ["game", "deterministic", "replay", "browser"],
  "files": ["src", "bin", "studio", "examples", "docs", "README.md", "SPEC.md", "ARCHITECTURE.md", "LICENSE"]
}
